# VideoForge — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── ElevenLabs (voice.provider = 'elevenlabs') ──────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── OpenAI (voice.provider = 'openai') ──────────────────────────────────────
# Uses model tts-1. Set openai_voice in config.json (default: alloy).
OPENAI_API_KEY=

# ── Leonardo.AI (Phase 4) ───────────────────────────────────────────────────
LEONARDO_API_KEY=

# ── Pexels (Phase 4 fallback) ───────────────────────────────────────────────
PEXELS_API_KEY=

# ── TikTok (Phase 8) ────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── YouTube (Phase 8) ───────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── Flask ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
FLASK_PORT=5000

# ── Reddit Stories ──────────────────────────────────────────────────────────
# Create a "script" app at https://www.reddit.com/prefs/apps to get these.
# Leave blank to disable Reddit scanning — scan-reddit skips gracefully.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=VideoForge/1.0 by u/yourusername

# ── Database sync (Phase 11.v1.A) ───────────────────────────────────────────
# Leave blank to use default local path (videoforge.db in project root).
# Set to a Dropbox/Drive path to share the database across devices.
VIDEOFORGE_DB_PATH=

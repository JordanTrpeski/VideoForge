# VideoForge — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Claude / Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── ElevenLabs (Phase 3) ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Leonardo.AI (Phase 4) ───────────────────────────────────────────────────
LEONARDO_API_KEY=

# ── Pexels (Phase 4 fallback) ───────────────────────────────────────────────
PEXELS_API_KEY=

# ── TikTok (Phase 8) ────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── YouTube (Phase 8) ───────────────────────────────────────────────────────
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── Flask ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
FLASK_PORT=5000

# ── Database sync (Phase 11.v1.A) ───────────────────────────────────────────
# Leave blank to use default local path (videoforge.db in project root).
# Set to a Dropbox/Drive path to share the database across devices.
VIDEOFORGE_DB_PATH=

{
  "default_channel": "engineering_brief",
  "captions": {
    "color": "white",
    "font_file": "assets/fonts/Arial-Bold.ttf",
    "font_size": 56,
    "max_chars_per_line": 32,
    "max_words_per_line": 4,
    "position_y_percent": 0.72,
    "stroke_color": "black",
    "stroke_width": 3,
    "whisper_model": "base"
  },
  "channel": {
    "handle": "HowThingsWorkEng",
    "name": "The Engineering Brief",
    "niche": "engineering",
    "platforms": [
      "tiktok",
      "youtube_shorts"
    ],
    "target_length_seconds": 70
  },
  "logging": {
    "keep_logs_days": 30,
    "level": "DEBUG",
    "max_log_size_mb": 50
  },
  "metadata": {
    "default_hashtags": [
      "#engineering",
      "#howthingswork",
      "#science",
      "#learnontiktok",
      "#education"
    ],
    "description_max_chars": 150,
    "hashtag_count": 10,
    "prompt_file": "prompts/metadata_prompt.txt",
    "youtube_description_max_chars": 500,
    "description_skeletons": [
      "Ever wondered {topic}? Most people have no idea.\n\n{youtube_description}\n\nFollow for weekly engineering secrets.\n\n#Shorts",
      "{youtube_description}\n\n{topic} — the engineering nobody explains simply.\n\nFollow @HowThingsWorkEng for weekly breakdowns.\n\n#Shorts",
      "Here's what school never taught you about {topic}.\n\n{youtube_description}\n\nMore real engineering every week — follow to not miss it.\n\n#Shorts"
    ]
  },
  "pipeline": {
    "visual_mode": "images"
  },
  "reddit": {
    "default_subs": [
      "tifu",
      "AmItheAsshole",
      "relationship_advice"
    ],
    "min_upvotes": 2000,
    "scan_limit": 25
  },
  "posting": {
    "auto_post_after_review": false,
    "batch_size_per_week": 5,
    "tiktok_post_times": [
      "07:00",
      "13:00",
      "19:00"
    ],
    "timezone": "Europe/Skopje",
    "youtube_post_times": [
      "08:00",
      "14:00",
      "20:00"
    ]
  },
  "research": {
    "fast_track_window_hours": 48,
    "notify_email": "",
    "priority_alert_fit_minimum": 7,
    "priority_alert_threshold": 100,
    "safe_scans_per_day": 15,
    "safe_scans_per_hour": 5,
    "scan_on_startup": false,
    "scan_on_startup_cooldown_hours": 2,
    "scoring_weights": {
      "channel_fit": 0.25,
      "competition": 0.3,
      "performance": 0.15,
      "trend": 0.3
    },
    "seed_keywords": {
      "elec": [
        "electrical engineering",
        "battery",
        "circuit",
        "power grid",
        "electronics failure"
      ],
      "flaw": [
        "engineering failure",
        "design flaw",
        "product recall",
        "structural failure",
        "engineering disaster"
      ],
      "infra": [
        "bridge engineering",
        "building collapse",
        "construction failure",
        "dam",
        "skyscraper"
      ],
      "vehicle": [
        "car engineering",
        "aircraft failure",
        "electric vehicle",
        "train derailment",
        "engine"
      ]
    }
  },
  "script": {
    "hook_style": "shocking_fact",
    "images_to_generate": 8,
    "language": "en",
    "max_tokens": 4096,
    "model": "claude-sonnet-4-6",
    "prompt_file": "prompts/script_prompt.txt",
    "reddit_prompt_file": "prompts/reddit_rewrite_prompt.txt",
    "temperature": 0.7,
    "word_count_target": 175
  },
  "thumbnail": {
    "mode": "frame_capture",
    "frame_capture_at_seconds": 5,
    "height": 1920,
    "overlay_template": "assets/thumbnail_template/overlay.png",
    "width": 1080,
    "text_template": {
      "output_width": 1280,
      "output_height": 720,
      "background_color": [15, 15, 25],
      "text_color": [255, 255, 255],
      "font_file": "assets/fonts/Arial-Bold.ttf",
      "font_size": 110,
      "stroke_color": [0, 0, 0],
      "stroke_width": 5,
      "frame_strip_height_pct": 0.28,
      "variant_accents": [
        [59, 130, 246],
        [239, 68, 68]
      ]
    }
  },
  "video": {
    "bitrate": "8000k",
    "codec": "h264",
    "fps": 30,
    "height": 1920,
    "music_volume_db": -18,
    "transition_duration": 0.3,
    "voice_volume_db": 0,
    "width": 1080
  },
  "visuals": {
    "guidance_scale": 7,
    "height": 1536,
    "model": "leonardo-diffusion-xl",
    "negative_prompt": "text, watermarks, logos, faces, blurry, low quality, nsfw, people, humans, words, letters, painting, illustration, cartoon, anime, render, 3D, CGI, artificial, plastic, fake, digital art, concept art, oversaturated",
    "num_images": 1,
    "num_inference_steps": 30,
    "style_preset_id": "DYNAMIC",
    "width": 864
  },
  "kill_metrics": {
    "minimum_impressions_for_verdict": 500,
    "checkpoint_v15": {
      "avg_ctr_warn": 0.03,
      "avg_retention_warn_pct": 30.0
    },
    "checkpoint_v30": {
      "breakout_views_threshold": 10000,
      "avg_ctr_kill": 0.04
    },
    "checkpoint_d60": {
      "yt_watch_hours_target": 4000,
      "yt_watch_hours_days": 365
    }
  },
  "variation": {
    "shorts": {
      "length_targets_seconds": [55, 70, 85],
      "hook_styles": [
        "shocking_fact",
        "wrong_assumption",
        "nobody_talks_about_this",
        "counterintuitive",
        "hidden_mechanism"
      ]
    },
    "reddit_long_form": {
      "length_targets_seconds": [480, 600, 720],
      "hook_styles": [
        "shocking_revelation",
        "relatable_mistake",
        "unexpected_twist",
        "dramatic_opening",
        "moral_dilemma"
      ]
    }
  },
  "voice": {
    "provider": "elevenlabs",
    "chunk_by_section": false,
    "output_format": "mp3_44100_128",
    "similarity_boost": 0.8,
    "stability": 0.65,
    "style_exaggeration": 0.2,
    "voice_id": "SET_IN_ENV",
    "openai_voice": "alloy",
    "kokoro_voice": "af_heart"
  }
}
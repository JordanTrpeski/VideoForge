<script>
const STAGE_ORDER = ['generate-script','generate-voice','generate-images','assemble',
                     'add-captions','generate-metadata','generate-thumbnail'];
let pollTimer = null;

function dotClass(status) {
    return { pending:'dot-pending', running:'dot-running', done:'dot-done',
             skipped:'dot-skipped', failed:'dot-failed' }[status] || 'dot-pending';
}

async function pollStatus() {
    try {
        const res = await fetch('/api/pipeline-status');
        const data = await res.json();

        const idleEl    = document.getElementById('ps-idle');
        const runningEl = document.getElementById('ps-running');
        const errEl     = document.getElementById('ps-error');
        const badge     = document.getElementById('ps-job-badge');

        const anyActivity = data.running || (data.job_id && data.stages &&
            Object.values(data.stages).some(s => s.status !== 'pending'));

        if (anyActivity) {
            idleEl.classList.add('hidden');
            runningEl.classList.remove('hidden');
            badge.textContent = data.job_id ? `JOB ${data.job_id}` : '';
            badge.className = `badge ${data.running ? 'badge-blue' : 'badge-gray'} text-xs`;

            data.stages.forEach(s => {
                const row = document.querySelector(`.stage-row[data-stage="${s.name}"]`);
                if (!row) return;
                const dot = row.querySelector('.dot');
                dot.className = `dot w-2.5 h-2.5 rounded-full flex-shrink-0 ${dotClass(s.status)}`;
                row.querySelector('.stage-msg').textContent = s.message || '';
                row.querySelector('.stage-elapsed').textContent = s.elapsed ? `${s.elapsed}s` : '';
            });

            if (data.error) {
                errEl.textContent = `Error: ${data.error}`;
                errEl.classList.remove('hidden');
            } else {
                errEl.classList.add('hidden');
            }
        } else {
            idleEl.classList.remove('hidden');
            runningEl.classList.add('hidden');
            badge.textContent = '';
        }
    } catch(e) { /* silent */ }
}

pollStatus();
setInterval(pollStatus, 5000);
</script>


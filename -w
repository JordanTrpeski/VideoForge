    <style>
        :root {
            --bg:      #0b1120;
            --surface: #111827;
            --card:    #1a2235;
            --border:  #263148;
            --muted:   #4b5a72;
        }
        body        { background: var(--bg); }
        .sidebar    { background: #0d1526; border-right: 1px solid var(--border); }
        .card       { background: var(--card); border: 1px solid var(--border); }
        .badge      { display: inline-flex; align-items: center; padding: 2px 8px;
                      border-radius: 9999px; font-size: 11px; font-weight: 600; letter-spacing: .03em; }

        /* status badge colours */
        .badge-gray   { background: #1f2937; color: #9ca3af; }
        .badge-blue   { background: #1e3a5f; color: #60a5fa; }
        .badge-amber  { background: #431407; color: #fbbf24; }
        .badge-purple { background: #2e1065; color: #c084fc; }
        .badge-green  { background: #052e16; color: #4ade80; }
        .badge-red    { background: #450a0a; color: #f87171; }

        /* stage dot colours */
        .dot-pending  { background: #374151; }
        .dot-running  { background: #3b82f6; animation: pulse 1.5s infinite; }
        .dot-done     { background: #22c55e; }
        .dot-skipped  { background: #6b7280; }
        .dot-failed   { background: #ef4444; }

        /* log line colours */
        .log-debug    { color: #4b5a72; }
        .log-info     { color: #60a5fa; }
        .log-warning  { color: #fbbf24; }
        .log-error    { color: #f87171; }

        /* nav link */
        .nav-link {
            display: flex; align-items: center; gap: 8px;
            padding: 6px 8px; border-radius: 6px;
            color: #6b7280; margin-bottom: 2px;
            font-size: 13px; text-decoration: none;
            transition: background .12s, color .12s;
        }
        .nav-link:hover { background: #1a2235; color: #e2e8f0; }
        .nav-link.active { background: #1e3a5f; color: #60a5fa; }
        .nav-link svg   { flex-shrink: 0; }

        /* form inputs */
        .inp {
            background: #0d1526; border: 1px solid var(--border);
            border-radius: 6px; color: #e2e8f0; font-size: 13px;
            padding: 6px 10px; outline: none; width: 100%;
        }
        .inp:focus { border-color: #3b82f6; }
        select.inp option { background: #0d1526; }

        /* buttons */
        .btn { display: inline-flex; align-items: center; gap: 6px;
               padding: 7px 14px; border-radius: 6px; font-size: 13px;
               font-weight: 500; cursor: pointer; transition: opacity .12s;
               border: none; text-decoration: none; }
        .btn:hover { opacity: .85; }
        .btn-primary  { background: #2563eb; color: #fff; }
        .btn-success  { background: #16a34a; color: #fff; }
        .btn-danger   { background: #dc2626; color: #fff; }
        .btn-warning  { background: #d97706; color: #fff; }
        .btn-ghost    { background: #1a2235; color: #9ca3af; border: 1px solid var(--border); }

        /* table */
        .tbl th { color: #6b7280; font-size: 11px; text-transform: uppercase;
                  letter-spacing: .06em; padding: 8px 12px; border-bottom: 1px solid var(--border); }
        .tbl td { padding: 10px 12px; border-bottom: 1px solid #161e2e; font-size: 13px; }
        .tbl tr:hover td { background: #1a2235; }
        .tbl tr:last-child td { border-bottom: none; }

        textarea { resize: vertical; }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: .4; }
        }

        /* scrollbar */
        ::-webkit-scrollbar       { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #263148; border-radius: 3px; }
    </style>
